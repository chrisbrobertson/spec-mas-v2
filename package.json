{
  "name": "spec-mas-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "corepack pnpm --filter @specmas/web dev",
    "dev:api": "API_PORT=3100 API_HOST=0.0.0.0 CORS_ORIGIN=http://localhost:3000 corepack pnpm --filter @specmas/api dev",
    "dev:full": "node scripts/dev-full.mjs",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test:unit": "corepack pnpm -r --if-present test:unit",
    "test:integration": "corepack pnpm -r --if-present test:integration",
    "test:e2e": "corepack pnpm -r --if-present test:e2e",
    "build": "corepack pnpm -r --if-present build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "22.13.8",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "@typescript-eslint/parser": "8.25.0",
    "eslint": "9.21.0",
    "prettier": "3.5.2",
    "prisma": "6.4.1",
    "typescript": "5.8.2",
    "vitest": "3.0.7"
  },
  "dependencies": {
    "@prisma/client": "6.4.1",
    "commander": "13.1.0",
    "fastify": "5.2.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "yaml": "2.7.0",
    "zod": "3.24.2"
  }
}
